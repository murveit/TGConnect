<?xml version="1.0" encoding="utf-8"?>
<!-- 
 * Settings Activity Layout - Algorithmic Overview
 *
 * 1. INITIALIZATION:
 * - Establishes a scrolling vertical list architecture to safely accommodate all system preferences.
 * - Wraps the hierarchy with an AppBarLayout to instantiate the navigation toolbar.
 *
 * 2. CALLING PROCEDURE:
 * - Inflated by SettingsActivity.java when the user opens the settings menu.
 *
 * 3. INTERNAL ALGORITHMIC LOGIC:
 * - Architecture: Uses a root LinearLayout within a ScrollView. This guarantees that elements 
 * flow sequentially and mathematically prevents the Z-axis overlapping issues common in 
 * broken ConstraintLayout chains.
 * - Compaction: Checkbox minHeight and vertical margins are minimized to reduce white space.
 * - Alignment: Uses nested horizontal LinearLayouts to pair labels with their corresponding 
 * input widgets (Gain, Exp Comp, Pruning) on a single visual line.
 *
 * 4. EXPECTED OUTPUTS / SIDE EFFECTS:
 * - Defines the visual hierarchy and widget IDs bound during SettingsActivity initialization.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="?android:attr/colorBackground">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="32dp"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorPrimary"
            app:navigationIcon="?attr/homeAsUpIndicator"
            app:popupTheme="@style/ThemeOverlay.AppCompat.Light">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Settings"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@android:color/white" />
                
        </com.google.android.material.appbar.MaterialToolbar>

    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="16dp"
            android:paddingBottom="32dp">

            <!-- NETWORK & CONNECTION -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Connection Target:"
                    android:textColor="?android:attr/textColorPrimary" />

                <Spinner
                    android:id="@+id/spnConnectionTarget"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginBottom="8dp"
                android:background="?android:attr/listDivider" />

            <!-- CAMERA HARDWARE CONTROLS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Exp Low:"
                    android:textColor="?android:attr/textColorPrimary" />

                <EditText
                    android:id="@+id/etExposureLow"
                    android:layout_width="110dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:inputType="number" />

                <TextView
                    android:id="@+id/tvExposureLowSeconds"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="(0.0s)" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Exp High:"
                    android:textColor="?android:attr/textColorPrimary" />

                <EditText
                    android:id="@+id/etExposureHigh"
                    android:layout_width="110dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:inputType="number" />

                <TextView
                    android:id="@+id/tvExposureHighSeconds"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="(0.0s)" />
            </LinearLayout>

            <!-- Analog Gain + Digital Gain on one line -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Analog gain:"
                    android:textColor="?android:attr/textColorPrimary" />

                <EditText
                    android:id="@+id/etGain"
                    android:layout_width="64dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:inputType="numberDecimal" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Digital gain:"
                    android:textColor="?android:attr/textColorPrimary" />

                <EditText
                    android:id="@+id/etDigitalGain"
                    android:layout_width="64dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:inputType="numberDecimal" />
            </LinearLayout>

            <!-- Inline Exposure Compensation -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:id="@+id/tvExpCompLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Exp Comp: 0.0"
                    android:textColor="?android:attr/textColorPrimary" />

                <SeekBar
                    android:id="@+id/sbExpComp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:max="16"
                    android:progress="8" />
            </LinearLayout>

            <!-- CAMERA LOCK CHECKBOXES -->
            <CheckBox
                android:id="@+id/cbAeLock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="32dp"
                android:layout_marginTop="8dp"
                android:text="Auto Exposure Lock" />

            <CheckBox
                android:id="@+id/cbAwbLock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="32dp"
                android:text="Auto White Balance Lock" />

            <!-- AUDIO SECTION -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:background="?android:attr/listDivider" />

            <CheckBox
                android:id="@+id/cbVoiceCalls"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="32dp"
                android:text="Voice calls (Out, Fault, Let)" />

            <CheckBox
                android:id="@+id/cbNanoAudio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="32dp"
                android:text="Nano Audio" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="In Serves:"
                    android:textColor="?android:attr/textColorPrimary" />

                <RadioGroup
                    android:id="@+id/rgInServe"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginStart="8dp">

                    <RadioButton
                        android:id="@+id/rbInServeMph"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MPH" />

                    <RadioButton
                        android:id="@+id/rbInServeBeep"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Beep" />

                    <RadioButton
                        android:id="@+id/rbInServeMute"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mute" />

                </RadioGroup>
            </LinearLayout>

            <!-- End of Point Beeps: SINGLES/DOUBLES only. Plays a double-beep when a point
                 ends without a voice call (e.g. double bounce, net crash, voice off). -->
            <CheckBox
                android:id="@+id/cbEndOfPointBeeps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="32dp"
                android:text="End of Point Beeps" />

            <!-- In-Point Beeps: SINGLES/DOUBLES only. Plays a single beep each time a new
                 bounce is confirmed mid-rally, for real-time audio feedback during a point. -->
            <CheckBox
                android:id="@+id/cbInCalls"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="32dp"
                android:text="In-Point Beeps" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="8dp"
                android:background="?android:attr/listDivider" />

            <CheckBox
                android:id="@+id/cbEnableLogging"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="32dp"
                android:text="Enable Detailed Tracking Logs" />

            <!-- ALGORITHMIC TUNING -->
                
            <CheckBox
                android:id="@+id/cbDebugCalibration"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="32dp"
                android:text="Use Debug Calibration Files" />

            <CheckBox
                android:id="@+id/cbUseCannedCalibration"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="32dp"
                android:text="Use Canned Calibration Image" />

            <CheckBox
                android:id="@+id/cbDebugAudio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="32dp"
                android:text="Debug Audio" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:background="?android:attr/listDivider" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvDetThreshLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pruning:"
                    android:textColor="?android:attr/textColorPrimary" />
                    
                <EditText
                    android:id="@+id/etDetThresh"
                    android:layout_width="48dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:inputType="number"
                    android:maxLength="2" />

                <TextView
                    android:id="@+id/tvServeThreshLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Serve Pruning:"
                    android:textColor="?android:attr/textColorPrimary" />

                <EditText
                    android:id="@+id/etServeThresh"
                    android:layout_width="48dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:inputType="number"
                    android:maxLength="2" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:background="?android:attr/listDivider" />

            <!-- SYSTEM ACTIONS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_horizontal"
                android:layout_marginTop="16dp">

                <Button
                    android:id="@+id/btnClearLogs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Clear Logs"
                    android:textAllCaps="false" />

                <Space
                    android:layout_width="16dp"
                    android:layout_height="wrap_content" />

                <Button
                    android:id="@+id/btnShareLogs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Share Logs"
                    android:textAllCaps="false" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvAudioStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="Nano audio: unknown"
                android:textColor="?android:attr/textColorSecondary" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_horizontal"
                android:layout_marginTop="4dp">

                <Button
                    android:id="@+id/btnTestAudio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Test Nano Audio"
                    android:textAllCaps="false" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_horizontal"
                android:layout_marginTop="4dp">

                <Button
                    android:id="@+id/btnInsertFakeCalls"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Insert Fake Calls"
                    android:textAllCaps="false" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
