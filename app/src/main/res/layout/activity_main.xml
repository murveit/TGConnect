<?xml version="1.0" encoding="utf-8"?>
<!-- 
 * Main Activity Layout - Algorithmic Overview
 *
 * 1. INITIALIZATION:
 * - Establishes the root CoordinatorLayout and vertical LinearLayout structure.
 *
 * 2. CALLING PROCEDURE:
 * - Inflated by MainActivity.java upon application launch.
 *
 * 3. INTERNAL ALGORITHMIC LOGIC:
 * - Implements a UI state machine utilizing a FrameLayout. It holds 4 discrete 
 * sub-layouts (llHome, llRawRecording, llTennisMenu, llActiveTennis) and toggles 
 * their visibility (View.GONE / View.VISIBLE) based on the application state.
 * - Utilizes vector drawables (@drawable/ic_check) for calibration status, relying 
 * on programmatic tinting (app:tint) rather than legacy system drawables to avoid 
 * theme-forced background colors.
 *
 * 4. EXPECTED OUTPUTS / SIDE EFFECTS:
 * - Defines the visual hierarchy and widget IDs bound during MainActivity initialization.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Universal Top Control Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingBottom="8dp">

            <Button
                android:id="@+id/btnBack"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Back"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnConnect"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONNECT" />

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <ImageButton
                android:id="@+id/btnSettings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Settings"
                android:src="@drawable/outline_control_camera_24"
                app:tint="?attr/colorOnSurface" />

            <ImageButton
                android:id="@+id/btnPowerOff"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:padding="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Power Off Server"
                android:src="@drawable/ic_power_off"
                app:tint="?attr/colorOnSurface" />
        </LinearLayout>

        <!-- Global Status Lines -->
        <TextView
            android:id="@+id/tvStatus1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status:"
            android:textColor="#808080"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/tvStatus2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="12dp"
            android:textColor="#808080"
            tools:text="Line 2" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- STATE 1: Home Screen -->
            <LinearLayout
                android:id="@+id/llHome"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvHomeMessage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Please Connect to TennisGenius"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/llHomeButtons"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <Button
                        android:id="@+id/btnGoRawRecording"
                        android:layout_width="match_parent"
                        android:layout_height="80dp"
                        android:layout_marginBottom="16dp"
                        android:text="Recording"
                        android:textSize="18sp" />

                    <Button
                        android:id="@+id/btnGoTennis"
                        android:layout_width="match_parent"
                        android:layout_height="80dp"
                        android:text="Tennis"
                        android:textSize="18sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- STATE 2: Raw Recording UI -->
            <LinearLayout
                android:id="@+id/llRawRecording"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <Button
                        android:id="@+id/btnStartRecording"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="4dp"
                        android:layout_weight="1"
                        android:text="Start Recording" />

                    <Button
                        android:id="@+id/btnCapturePhotos"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_weight="1"
                        android:text="Capture Photos" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:layout_marginBottom="4dp">

                        <ImageView
                            android:id="@+id/ivImage1"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="#CCCCCC"
                            android:scaleType="fitCenter" />

                        <com.murveit.tgcontrol.HistogramView
                            android:id="@+id/histView1"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:visibility="gone" />
                    </FrameLayout>

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:layout_marginTop="4dp">

                        <ImageView
                            android:id="@+id/ivImage2"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="#CCCCCC"
                            android:scaleType="fitCenter" />

                        <com.murveit.tgcontrol.HistogramView
                            android:id="@+id/histView2"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:visibility="gone" />
                    </FrameLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- STATE 3: Tennis Menu UI -->
            <LinearLayout
                android:id="@+id/llTennisMenu"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvSelectPlayMode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:text="Select Play Mode"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:paddingBottom="16dp" />

                <CheckBox
                    android:id="@+id/cbRecordSession"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="Record"
                    android:textSize="18sp" />

                <Button android:id="@+id/btnModeSingles" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Singles Match" />
                <Button android:id="@+id/btnModeDoubles" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Doubles Match" />
                <Button android:id="@+id/btnModeServe" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Serve Practice" />
                <Button android:id="@+id/btnModeRally" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Rally Practice" />

                <Space android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="System Calibration"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:paddingBottom="8dp" />

                <!-- Left Calibration Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <Button
                        android:id="@+id/btnCalibrateLeft"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Calibrate Left (Cam 0)" />
                    <ImageView
                        android:id="@+id/ivCheckLeft"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginStart="8dp"
                        android:src="@drawable/ic_check"
                        app:tint="#4CAF50"
                        android:visibility="gone" />
                </LinearLayout>

                <!-- Right Calibration Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <Button
                        android:id="@+id/btnCalibrateRight"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Calibrate Right (Cam 1)" />
                    <ImageView
                        android:id="@+id/ivCheckRight"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginStart="8dp"
                        android:src="@drawable/ic_check"
                        app:tint="#4CAF50"
                        android:visibility="gone" />
                </LinearLayout>
            </LinearLayout>

            <!-- STATE 4: Active Tennis Tracking UI -->
            <LinearLayout
                android:id="@+id/llActiveTennis"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvTennisModeTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Singles Match"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:paddingBottom="16dp" />

                <TextView
                    android:id="@+id/tvLiveTelemetry"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="0:00 ⏱️ 0.0 FPS"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:paddingBottom="16dp"
                    android:textColor="#A0A0A0" />

                <Button
                    android:id="@+id/btnStartTracking"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:text="Start"
                    android:textSize="18sp"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Play-by-Play Events:"
                    android:textStyle="bold"
                    android:paddingBottom="4dp" />

                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:background="#888888"
                    android:padding="2dp">
                    <TextView
                        android:id="@+id/tvTrackingLog"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="200dp"
                        android:background="#000000"
                        android:padding="8dp"
                        android:textSize="14sp"
                        android:textColor="#FFFFFF"
                        android:text="System Initialized.\nWaiting for start command..." />
                </ScrollView>
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
