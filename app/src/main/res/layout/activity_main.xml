<?xml version="1.0" encoding="utf-8"?>
<!-- 
 * Main Activity Layout - Algorithmic Overview
 *
 * 1. INITIALIZATION:
 * - Establishes the root CoordinatorLayout and vertical LinearLayout structure.
 *
 * 2. CALLING PROCEDURE:
 * - Inflated by MainActivity.java upon application launch.
 *
 * 3. INTERNAL ALGORITHMIC LOGIC:
 * - Implements a UI state machine utilizing a FrameLayout. It holds 4 discrete 
 * sub-layouts (llHome, llRawRecording, llTennisMenu, llActiveTennis) and toggles 
 * their visibility (View.GONE / View.VISIBLE) based on the application state.
 * - Utilizes vector drawables (@drawable/ic_check) for calibration status, relying 
 * on programmatic tinting (app:tint) rather than legacy system drawables to avoid 
 * theme-forced background colors.
 *
 * 4. EXPECTED OUTPUTS / SIDE EFFECTS:
 * - Defines the visual hierarchy and widget IDs bound during MainActivity initialization.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Universal Top Control Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingBottom="8dp">

            <Button
                android:id="@+id/btnBack"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Back"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnConnect"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONNECT" />

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <!-- Replaced ImageButton with a TextButton emoji to avoid missing asset crashes -->
            <Button
                android:id="@+id/btnDebugAudio"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎾"
                android:textSize="20sp"
                android:visibility="gone" />

            <ImageButton
                android:id="@+id/btnSettings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Settings"
                android:src="@drawable/outline_control_camera_24"
                app:tint="?attr/colorOnSurface" />

            <ImageButton
                android:id="@+id/btnPowerOff"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:padding="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Power Off Server"
                android:src="@drawable/ic_power_off"
                app:tint="?attr/colorOnSurface" />
        </LinearLayout>

        <!-- Network reachability indicator: shown only in STATE_DISCONNECTED -->
        <TextView
            android:id="@+id/tvNetworkStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="2dp"
            android:textSize="11sp"
            android:visibility="gone" />

        <!-- Global Status Lines -->
        <TextView
            android:id="@+id/tvStatus1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status:"
            android:textColor="#808080"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/tvStatus2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="12dp"
            android:textColor="#808080"
            tools:text="Line 2" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- STATE 1: Home Screen -->
            <LinearLayout
                android:id="@+id/llHome"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvHomeMessage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Please Connect to TennisGenius"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/llHomeButtons"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <Button
                        android:id="@+id/btnGoRawRecording"
                        android:layout_width="match_parent"
                        android:layout_height="80dp"
                        android:layout_marginBottom="16dp"
                        android:text="Recording"
                        android:textSize="18sp" />

                    <Button
                        android:id="@+id/btnGoTennis"
                        android:layout_width="match_parent"
                        android:layout_height="80dp"
                        android:text="Tennis"
                        android:textSize="18sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- STATE 2: Raw Recording UI -->
            <LinearLayout
                android:id="@+id/llRawRecording"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <Button
                        android:id="@+id/btnStartRecording"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="4dp"
                        android:layout_weight="1"
                        android:text="Start Recording" />

                    <Button
                        android:id="@+id/btnCapturePhotos"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_weight="1"
                        android:text="Capture Photos" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:layout_marginBottom="4dp">

                        <ImageView
                            android:id="@+id/ivImage1"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="#CCCCCC"
                            android:scaleType="fitCenter" />

                        <com.murveit.tgcontrol.HistogramView
                            android:id="@+id/histView1"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:visibility="gone" />
                    </FrameLayout>

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:layout_marginTop="4dp">

                        <ImageView
                            android:id="@+id/ivImage2"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="#CCCCCC"
                            android:scaleType="fitCenter" />

                        <com.murveit.tgcontrol.HistogramView
                            android:id="@+id/histView2"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:visibility="gone" />
                    </FrameLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- STATE 3: Tennis Menu UI -->
            <LinearLayout
                android:id="@+id/llTennisMenu"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvSelectPlayMode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:text="Select Play Mode"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:paddingBottom="16dp" />

                <CheckBox
                    android:id="@+id/cbRecordSession"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="Record"
                    android:textSize="18sp" />

                <Button android:id="@+id/btnModeSingles" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Singles Match" />
                <Button android:id="@+id/btnModeDoubles" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Doubles Match" />
                <Button android:id="@+id/btnModeServe" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Serve Practice" />
                <Button android:id="@+id/btnModeRally" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Rally Practice" />

                <Space android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" />

                <!-- Left Calibration Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <Button
                            android:id="@+id/btnCalibrateLeft"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Calibrate Left (Cam 0)" />
                        <ImageView
                            android:id="@+id/ivCheckLeft"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_marginStart="8dp"
                            android:src="@drawable/ic_check"
                            app:tint="#4CAF50"
                            android:visibility="gone" />
                    </LinearLayout>
                    
                    <TextView
                        android:id="@+id/tvPoseLeft"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:gravity="center"
                        android:layout_marginTop="-4dp"
                        android:layout_marginBottom="4dp"
                        android:textColor="#A0A0A0"
                        android:visibility="gone"
                        tools:text="x,y,z -6.23,0.25,0.01m r,p,y=1.2,2.3,0.1º" />
                </LinearLayout>

                <!-- Right Calibration Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:orientation="vertical">
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <Button
                            android:id="@+id/btnCalibrateRight"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Calibrate Right (Cam 1)" />
                        <ImageView
                            android:id="@+id/ivCheckRight"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_marginStart="8dp"
                            android:src="@drawable/ic_check"
                            app:tint="#4CAF50"
                            android:visibility="gone" />
                    </LinearLayout>
                    
                    <TextView
                        android:id="@+id/tvPoseRight"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:gravity="center"
                        android:layout_marginTop="-4dp"
                        android:layout_marginBottom="4dp"
                        android:textColor="#A0A0A0"
                        android:visibility="gone"
                        tools:text="x,y,z 6.23,0.25,0.01m r,p,y=1.2,2.3,0.1º" />
                </LinearLayout>
            </LinearLayout>

            <!-- STATE 4: Active Tennis Tracking UI -->
            <LinearLayout
                android:id="@+id/llActiveTennis"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Title row: centered mode name + recording indicator on the right -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingBottom="16dp">

                    <TextView
                        android:id="@+id/tvTennisModeTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Singles Match"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_centerInParent="true" />

                    <ImageView
                        android:id="@+id/ivRecordingIndicator"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="12dp"
                        android:src="@drawable/ic_record_circle"
                        android:tint="#808080"
                        android:visibility="invisible"
                        android:contentDescription="Recording indicator" />
                </RelativeLayout>

                <TextView
                    android:id="@+id/tvLiveTelemetry"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="0:00 ⏱️ 0.0 FPS"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:paddingBottom="16dp"
                    android:textColor="#A0A0A0" />

                <!-- UNIFIED TRACKING CONTROLS (Responsive to Play Mode) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <Button
                        android:id="@+id/btnToggleView"
                        android:layout_width="0dp"
                        android:layout_height="60dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:text="Log"
                        android:textSize="14sp"
                        android:padding="0dp"
                        app:iconPadding="0dp"
                        android:insetLeft="0dp"
                        android:insetRight="0dp"
                        android:minWidth="0dp"
                        android:textAllCaps="false"
                        android:visibility="gone" />

                    <Button
                        android:id="@+id/btnStartTracking"
                        android:layout_width="0dp"
                        android:layout_height="60dp"
                        android:layout_weight="2"
                        android:text="Start"
                        android:textSize="18sp" />

                    <Button
                        android:id="@+id/btnClearServes"
                        android:layout_width="0dp"
                        android:layout_height="60dp"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:text="Clear"
                        android:textSize="14sp"
                        android:padding="0dp"
                        app:iconPadding="0dp"
                        android:insetLeft="0dp"
                        android:insetRight="0dp"
                        android:minWidth="0dp"
                        android:textAllCaps="false"
                        android:visibility="gone" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvAvgMph"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="0 serves, 0 In, -- MPH avg"
                    android:textAlignment="center"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:visibility="gone"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvLastServe"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ready for serves"
                    android:textAlignment="center"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:visibility="gone"
                    android:layout_marginBottom="8dp" />

                <!-- THE SCATTER PLOT -->
                <LinearLayout
                    android:id="@+id/llServePlotContainer"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:visibility="gone">
                
                    <com.murveit.tgcontrol.ServeScatterView
                        android:id="@+id/serveScatterView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"/>
                </LinearLayout>

                <!-- THE ORIGINAL TEXT LOG (Wrapped in a 1dp layout to create a border) -->
                <LinearLayout
                    android:id="@+id/llTrackingLogContainer"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:background="?android:attr/textColorPrimary"
                    android:padding="1dp">
                    
                    <ScrollView
                        android:id="@+id/svTrackingLog"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="?android:attr/colorBackground"
                        android:padding="8dp"
                        android:fillViewport="true">
                        
                        <TextView
                            android:id="@+id/tvTrackingLog"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="?android:attr/textColorPrimary" />
                    </ScrollView>
                </LinearLayout>

            </LinearLayout>
        </FrameLayout>
    </LinearLayout>

    <!-- Disconnect Overlay: rendered on top of all content via CoordinatorLayout z-ordering.
         Shown when WiFi drops while connected; dismissed on reconnect or full disconnect.
         Background is 80% opaque black to make the message legible over any screen state.
         The Disconnect button lets the user escape the grace period immediately rather than
         waiting for it to expire. -->
    <LinearLayout
        android:id="@+id/llDisconnectOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="WiFi Disconnected"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Waiting to reconnect..."
            android:textColor="#DDDDDD"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btnOverlayDisconnect"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Disconnect"
            android:textColor="#FFFFFF"
            android:backgroundTint="#AA444444" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
